<Window x:Class="TasbihCounter.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Opacity="0"
        IsHitTestVisible="False">

    <!-- Rounded card. Colors are updated per-dhikr from code-behind. -->
    <Border x:Name="Card"
            CornerRadius="16"
            Padding="28,20"
            MinWidth="160"
            Background="#E6161616">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center">
            <!-- Dhikr label (Arabic renders right-to-left). -->
            <TextBlock x:Name="LabelText"
                       Text="سُبْحَانَ اللّٰه"
                       FlowDirection="RightToLeft"
                       FontFamily="Segoe UI, Traditional Arabic, Amiri"
                       FontSize="22"
                       Foreground="#66E0A3"
                       HorizontalAlignment="Center"/>
            <!-- Big count. -->
            <TextBlock x:Name="CountText"
                       Text="0"
                       FontFamily="Segoe UI Semibold"
                       FontSize="72"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="0,-4,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
