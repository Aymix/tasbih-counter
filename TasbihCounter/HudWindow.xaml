<Window x:Class="TasbihCounter.HudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Opacity="0"
        IsHitTestVisible="False">

    <!-- Frosted glass without any DWM API: Backdrop holds a snapshot of the
         screen behind the HUD, blurred here in WPF. A tint sits on top for
         contrast, then the text. CardRoot is clipped to a rounded rect in
         code-behind (Border doesn't clip children to its CornerRadius). -->
    <Border x:Name="Card"
            CornerRadius="16"
            MinWidth="160"
            BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#59FFFFFF"/>
                <GradientStop Offset="1" Color="#1AFFFFFF"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid x:Name="CardRoot">
            <!-- Snapshot of what's behind the HUD.
                 This MUST be a Rectangle+ImageBrush, not an Image: an Image
                 reports its bitmap's natural size as its desired size, which
                 with SizeToContent makes the window grow to fit the snapshot —
                 and the snapshot is taken at window size + bleed, so the window
                 runs away to fullscreen. A Rectangle contributes no size.
                 The negative margin pushes the blur's soft edges outside the clip. -->
            <Rectangle x:Name="Backdrop" Margin="-32">
                <Rectangle.Fill>
                    <ImageBrush x:Name="BackdropBrush" Stretch="Fill"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <BlurEffect Radius="28" KernelType="Gaussian" RenderingBias="Quality"/>
                </Rectangle.Effect>
            </Rectangle>

            <!-- Tint over the blur: keeps text readable and gives it depth.
                 Kept deliberately light (~38-48%): at the previous 55-65% it
                 buried the blurred backdrop and the card read as flat dark,
                 especially over a dark desktop. Text stays legible via its own
                 drop shadows rather than by making this opaque. -->
            <Rectangle>
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#61222624"/>
                        <GradientStop Offset="1" Color="#7A121413"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Naqsh: seamless geometric tile drawn by make_naqsh.py, laid over
                 the frost. A Rectangle (no intrinsic size) so it can't affect the
                 window's SizeToContent measurement. -->
            <!-- Eased back from 0.20: the pattern was competing with the frost
                 rather than accenting it. -->
            <Rectangle x:Name="Naqsh" Opacity="0.13">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="naqsh.png"
                                TileMode="Tile"
                                Viewport="0,0,100,100"
                                ViewportUnits="Absolute"
                                Stretch="Fill"/>
                </Rectangle.Fill>
            </Rectangle>

            <StackPanel HorizontalAlignment="Center" Margin="28,20">
                <!-- Dhikr label (Arabic renders right-to-left). -->
                <TextBlock x:Name="LabelText"
                           Text="سُبْحَانَ اللّٰه"
                           FlowDirection="RightToLeft"
                           FontFamily="Segoe UI, Traditional Arabic, Amiri"
                           FontSize="22"
                           Foreground="#66E0A3"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Opacity="0.85" Color="#000000"/>
                    </TextBlock.Effect>
                </TextBlock>
                <!-- Big count. -->
                <TextBlock x:Name="CountText"
                           Text="0"
                           FontFamily="Segoe UI Semibold"
                           FontSize="72"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,-4,0,0"
                           HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.8" Color="#000000"/>
                    </TextBlock.Effect>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>
